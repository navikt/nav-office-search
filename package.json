{
    "name": "nav-office-search",
    "version": "1.2.6",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.2.0+sha512.cdd7e34ea0d237bed3fa89e633185027e3ecdad98ce7453032f4d4d83c10cb7b85b9afe8534048ab0a3cc10228bdd5e32f5f622d05d66e58f46177fe5601eab1",
    "scripts": {
        "build": "tsc --project packages/client/tsconfig.json --noEmit && pnpm --filter nav-office-search-client build:client && pnpm --filter nav-office-search-client build:ssr && pnpm --filter nav-office-search-server build",
        "start": "pnpm --filter nav-office-search-server start",
        "lint": "eslint . && pnpm --filter nav-office-search-client exec tsc --noEmit && pnpm --filter nav-office-search-server exec tsc --noEmit",
        "decorator": "docker compose up",
        "dev": "pnpm --filter nav-office-search-server dev",
        "prod-local": "pnpm --filter nav-office-search-server prod-local",
        "test": "pnpm --filter nav-office-search-client test",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@eslint/js": "9.39.3",
        "concurrently": "9.2.1",
        "eslint": "9.39.2",
        "eslint-plugin-react": "7.37.5",
        "husky": "9.1.7",
        "lint-staged": "16.3.1",
        "prettier": "3.8.1",
        "typescript": "5.9.3",
        "typescript-eslint": "8.56.1",
        "preact-render-to-string": "6.6.6"
    },
    "lint-staged": {
        "*.{js,jsx,json,md,ts,tsx,scss,css}": "prettier --write"
    }
}
