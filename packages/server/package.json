{
    "name": "nav-office-search-server",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "rm -fr dist && tsc",
        "start": "node dist/server/src/server.js",
        "start-local": "pnpm build && concurrently \"tsc -w\" \"nodemon -w dist/server dist/server/src/server.js\"",
        "prod-local": "cp .env.local-prod .env && pnpm start-local",
        "dev": "cp .env.development .env && pnpm start-local"
    },
    "dependenciesComments": {
        "@types/node": "Holdes på versjon 24.10.1 ellers brekker det. Nyeste versjon 25.0.6"
    },
    "dependencies": {
        "@navikt/nav-dekoratoren-moduler": "3.6.2",
        "compression": "1.8.1",
        "dotenv": "17.3.1",
        "express": "5.2.1",
        "lodash.debounce": "4.0.8",
        "lru-cache": "11.2.6",
        "node-cache": "5.1.2",
        "node-schedule": "2.1.1",
        "preact": "10.28.4",
        "preact-render-to-string": "6.6.6",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "vite": "7.3.2"
    },
    "devDependencies": {
        "@types/compression": "1.8.1",
        "@types/express": "5.0.6",
        "@types/node": "25.3.3",
        "@types/node-schedule": "2.1.8",
        "concurrently": "9.2.1",
        "fetch-mock": "11.1.5",
        "nodemon": "3.1.14"
    }
}
